{
  "name": "oatmeal",
  "version": "0.1.0",
  "description": "Hackathon platform",
  "private": true,
  "scripts": {
    "predev": "./scripts/setup-local-db.sh",
    "dev": "next dev",
    "dev:fresh": "./scripts/setup-local-db.sh && supabase db reset && bun run dev:skip-setup",
    "dev:skip-setup": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bun test",
    "db:sync": "supabase db reset && supabase gen types typescript --local > lib/db/types.ts",
    "db:diff": "supabase db diff -f",
    "update-types": "supabase gen types typescript --local > lib/db/types.ts",
    "update-types:remote": "supabase gen types typescript --project-id \"$PROJECT_REF\" > lib/db/types.ts",
    "gen:secret": "openssl rand -hex 32"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.12",
    "@base-ui/react": "^1.0.0",
    "@clerk/nextjs": "^6.36.7",
    "@clerk/themes": "^2.4.47",
    "@daytonaio/sdk": "^0.130.0",
    "@elysiajs/eden": "^1.4.6",
    "@elysiajs/swagger": "^1.3.1",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@supabase/supabase-js": "^2.90.1",
    "@workflow/ai": "^4.0.1-beta.44",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.33",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "elysia": "^1.4.21",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^16.4.6",
    "fumadocs-mdx": "^14.2.4",
    "fumadocs-ui": "^16.4.6",
    "lucide-react": "^0.562.0",
    "motion": "^12.26.2",
    "nanoid": "^5.1.6",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.7.0",
    "shadcn": "^3.6.3",
    "shiki": "^3.21.0",
    "streamdown": "^2.0.1",
    "tailwind-merge": "^3.4.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "workflow": "^4.0.1-beta.44",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "^1.3.5",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "happy-dom": "^20.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
