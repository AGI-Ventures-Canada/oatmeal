# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
packages/*/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# fumadocs auto-generated source index
.source/

# SDK dist
packages/sdk/dist/

# Generated JS files in source directories (from accidental tsc)
lib/**/*.js
lib/**/*.js.map

# fumadocs auto-generated source files
/.source/
lib/**/*.d.ts
lib/**/*.d.ts.map

# local dev
specs.md
examples/

# Claude Code
.claude/worktrees/
.claude/scheduled_tasks.lock

# Superset worktrees
.superset/

# IDE / tool config
.continue/
.factory/
cli.json

# supabase local
supabase/.branches
supabase/.temp

# production env backup
.env.local.production
.playwright-mcp/
